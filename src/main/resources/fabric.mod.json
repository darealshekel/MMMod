{
  "schemaVersion": 1,
  "id": "mmm",
  "version": "${version}",
  "name": "MMM",
  "description": "A Tweakeroo-style companion addon that adds mining tracking, HUD stats, projects, goals, notifications, and session summaries.",
  "authors": [
    "Shekel"
  ],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.mmm.MMM"
    ],
    "modmenu": [
      "com.mmm.gui.ModMenuCompat"
    ]
  },
  "mixins": [
    "mmm.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.14",
    "fabric-api": ">=${fabric_api_dependency}",
    "minecraft": "${minecraft_dependency}",
    "malilib": ">=${malilib_dependency}",
    "tweakeroo": ">=${tweakeroo_dependency}"
  }
}
