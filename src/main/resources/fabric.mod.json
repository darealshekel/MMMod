{
  "schemaVersion": 1,
  "id": "mmm",
  "version": "${version}",
  "name": "MMM",
  "description": "A Tweakeroo-style companion addon that adds mining tracking, HUD stats, projects, goals, notifications, and session summaries.",
  "authors": [
    "Shekel"
  ],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.mmm.MMM"
    ],
    "modmenu": [
      "com.mmm.gui.ModMenuCompat"
    ]
  },
  "mixins": [
    "mmm.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "fabric-api": ">=0.141.4",
    "minecraft": "${minecraft_dependency}",
    "malilib": ">=0.27.9",
    "tweakeroo": ">=0.27.7"
  }
}
